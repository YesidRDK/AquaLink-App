{
  "expo": {
    "name": "AquaLink",
    "slug": "AquaLink",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo-azul.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/logo-azul.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "backgroundColor": "#ffffff",
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo-azul.png",
        "backgroundColor": "#ffffff"  
      },
      "package": "com.tuusuario.aguabarinitas"
    },
    "web": {
      "favicon": "./assets/logo-azul.png"
    }
  }
}